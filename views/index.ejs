<!doctype html>
<html lang="en">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=no">
  <title>Baby Monitor</title>
  <style>
    :root {
      --bg-color: #0c0c0e;
      --panel-bg: rgba(28, 28, 30, 0.4);
      --text-primary: #ffffff;
      --text-secondary: #9a9a9e;
      --accent-color: #3b82f6;
      --accent-hover: #60a5fa;
      --border-color: rgba(255, 255, 255, 0.08);
      --glass-border: rgba(255, 255, 255, 0.12);
      --shadow-lg: 0 12px 40px -12px rgba(0, 0, 0, 0.8);
      --radius-full: 9999px;
      --radius-lg: 32px;
      --radius-md: 20px;
      --radius-sm: 12px;
    }

    @font-face {
      font-family: 'Outfit';
      src: url('https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600&display=swap');
    }

    * {
      box-sizing: border-box;
      -webkit-tap-highlight-color: transparent;
      outline: none;
    }

    body {
      font-family: 'Outfit', -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
      margin: 0;
      padding: 0;
      background: var(--bg-color);
      color: var(--text-primary);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color-scheme: dark;
      overflow-x: hidden;
    }

    .container {
      width: 100%;
      max-width: 1200px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 32px;
      padding: 24px;
      animation: fadeIn 0.8s ease-out;
    }

    @keyframes fadeIn {
      from {
        opacity: 0;
        transform: translateY(10px);
      }

      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .top-bar {
      width: 100%;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 16px;
      padding: 0 8px;
    }

    .title {
      display: flex;
      flex-direction: column;
      gap: 2px;
    }

    .title h1 {
      margin: 0;
      font-size: 24px;
      font-weight: 600;
      letter-spacing: -0.02em;
      background: linear-gradient(135deg, #fff 0%, #a1a1aa 100%);
      -webkit-background-clip: text;
      background-clip: text;
      -webkit-text-fill-color: transparent;
    }

    .subtitle {
      margin: 0;
      font-size: 13px;
      color: var(--text-secondary);
      font-weight: 300;
    }

    /* Video Player */
    .video-wrapper {
      width: 100%;
      position: relative;
      border-radius: var(--radius-lg);
      overflow: hidden;
      box-shadow: var(--shadow-lg);
      background: #000;
      aspect-ratio: 16/9;
      border: 1px solid var(--glass-border);
    }

    #video {
      width: 100%;
      height: 100%;
      object-fit: contain;
      display: block;
      transition: object-fit 0.3s ease;
    }

    #canvas_overlay {
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 5;
    }

    /* Floating Video Controls Overlay */
    .video-controls-overlay {
      position: absolute;
      inset: 0;
      z-index: 10;
      opacity: 0;
      transition: opacity 0.3s ease;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 20px;
      background: linear-gradient(0deg, rgba(0, 0, 0, 0.4) 0%, transparent 40%, transparent 60%, rgba(0, 0, 0, 0.4) 100%);
      pointer-events: none;
    }

    .video-wrapper:hover .video-controls-overlay {
      opacity: 1;
    }

    .overlay-actions-top {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
    }

    .overlay-actions-bottom {
      display: flex;
      justify-content: center;
      gap: 40px;
      align-items: center;
    }

    .video-overlay-msg {
      position: absolute;
      inset: 0;
      display: flex;
      align-items: center;
      justify-content: center;
      background: rgba(0, 0, 0, 0.7);
      backdrop-filter: blur(8px);
      z-index: 20;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s;
    }

    .video-overlay-msg.visible {
      opacity: 1;
      pointer-events: auto;
    }

    .msg-card {
      text-align: center;
      padding: 32px;
      max-width: 320px;
    }

    .msg-card h2 {
      margin: 0 0 8px;
      font-size: 20px;
      font-weight: 600;
    }

    .msg-card p {
      margin: 0 0 24px;
      font-size: 14px;
      color: var(--text-secondary);
      line-height: 1.5;
    }

    /* Floating Controls */
    .floating-btn {
      width: 48px;
      height: 48px;
      border-radius: var(--radius-full);
      background: rgba(255, 255, 255, 0.08);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--glass-border);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
      pointer-events: auto;
    }

    .floating-btn:hover {
      background: rgba(255, 255, 255, 0.15);
      transform: translateY(-2px);
      box-shadow: 0 8px 20px -6px rgba(0, 0, 0, 0.4);
    }

    .floating-btn:active {
      transform: translateY(0);
    }

    .floating-btn svg {
      width: 22px;
      height: 22px;
      fill: none;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
    }

    /* Directional/Joystick Hub */
    .control-hub {
      display: grid;
      grid-template-columns: repeat(3, 44px);
      grid-template-rows: repeat(3, 44px);
      gap: 10px;
      align-items: center;
      justify-content: center;
      pointer-events: auto;
    }

    .hub-btn.up {
      grid-area: 1 / 2 / 2 / 3;
    }

    .hub-btn.left {
      grid-area: 2 / 1 / 3 / 2;
    }

    .hub-btn.right {
      grid-area: 2 / 3 / 3 / 4;
    }

    .hub-btn.down {
      grid-area: 3 / 2 / 4 / 3;
    }

    .hub-btn {
      width: 44px;
      height: 44px;
      border-radius: 14px;
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--glass-border);
      color: white;
      display: flex;
      align-items: center;
      justify-content: center;
      cursor: pointer;
      transition: all 0.15s;
    }

    .hub-btn:hover {
      background: rgba(255, 255, 255, 0.12);
    }

    .hub-btn:active {
      transform: scale(0.92);
    }

    .hub-btn.center {
      background: var(--accent-color);
      border: none;
      box-shadow: 0 4px 15px -4px var(--accent-color);
    }

    .hub-btn svg {
      width: 20px;
      height: 20px;
      stroke-width: 2.5;
    }

    /* Action Buttons */
    .action-btn {
      padding: 10px 18px;
      border-radius: var(--radius-full);
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--glass-border);
      color: var(--text-primary);
      font-size: 13px;
      font-weight: 500;
      cursor: pointer;
      display: flex;
      align-items: center;
      gap: 8px;
      transition: all 0.2s;
    }

    .action-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: rgba(255, 255, 255, 0.2);
    }

    .action-btn.active {
      background: var(--accent-color);
      border-color: var(--accent-color);
    }

    /* Custom Switch */
    .toggle-group {
      display: flex;
      align-items: center;
      gap: 10px;
      cursor: pointer;
      user-select: none;
    }

    .switch {
      width: 40px;
      height: 22px;
      background: rgba(255, 255, 255, 0.1);
      border-radius: 20px;
      padding: 3px;
      transition: background 0.3s;
      position: relative;
    }

    .switch::after {
      content: '';
      width: 16px;
      height: 16px;
      background: white;
      border-radius: 50%;
      display: block;
      transition: transform 0.3s cubic-bezier(0.18, 0.89, 0.35, 1.15);
    }

    input:checked+.switch {
      background: var(--accent-color);
    }

    input:checked+.switch::after {
      transform: translateX(18px);
    }

    /* Status Toast */
    .status-toast {
      position: fixed;
      bottom: 40px;
      left: 50%;
      transform: translateX(-50%) translateY(100px);
      background: rgba(255, 255, 255, 0.95);
      color: #000;
      padding: 12px 24px;
      border-radius: var(--radius-full);
      font-size: 14px;
      font-weight: 600;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5);
      transition: transform 0.5s cubic-bezier(0.17, 0.84, 0.44, 1);
      z-index: 100;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .status-toast.visible {
      transform: translateX(-50%) translateY(0);
    }

    /* Responsive */
    @media (max-width: 768px) {
      .container {
        padding: 16px;
        gap: 20px;
      }

      .top-bar {
        flex-direction: column;
        align-items: flex-start;
        gap: 12px;
      }

      .video-controls-overlay {
        opacity: 1;
        pointer-events: auto;
        background: none;
      }

      .overlay-actions-top {
        display: none;
      }

      .video-wrapper:hover .video-controls-overlay {
        opacity: 1;
      }
    }

    @media (max-height: 500px) and (orientation: landscape) {
      .container {
        padding: 0;
        max-width: none;
      }

      .top-bar {
        display: none;
      }

      .video-wrapper {
        border-radius: 0;
        border: none;
        height: 100vh;
      }

    }
  </style>
</head>

<body>

  <div class="container">
    <header class="top-bar">
      <div class="title">
        <h1>Baby Monitor</h1>
        <p class="subtitle" id="hint">Arrow keys • +/- Zoom • F Fullscreen</p>
      </div>
    </header>

    <main class="video-wrapper">
      <img id="video" src="/video.mjpg" alt="Live Stream" decoding="async">
      <canvas id="canvas_overlay"></canvas>

      <!-- Premium Floating Controls -->
      <div class="video-controls-overlay">
        <div class="overlay-actions-top">
          <label class="toggle-group" title="Toggle AI Tracking" style="pointer-events: auto;">
            <input type="checkbox" id="trackingToggle" hidden>
            <div class="switch"></div>
          </label>
          <button class="floating-btn" id="quickReload" title="Refresh Stream">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
            </svg>
          </button>
          <button class="floating-btn" id="fsBtn" title="Fullscreen">
            <svg viewBox="0 0 24 24">
              <path d="M15 3h6v6M9 21H3v-6M21 3l-7 7M3 21l7-7" />
            </svg>
          </button>
        </div>

        <div class="overlay-actions-bottom">
          <div class="control-hub">
            <button class="hub-btn up" data-ptz="up" title="Up"><svg viewBox="0 0 24 24" fill="none"
                stroke="currentColor">
                <path d="M18 15l-6-6-6 6" />
              </svg></button>
            <button class="hub-btn left" data-ptz="left" title="Left"><svg viewBox="0 0 24 24" fill="none"
                stroke="currentColor">
                <path d="M15 18l-6-6 6-6" />
              </svg></button>
            <button class="hub-btn right" data-ptz="right" title="Right"><svg viewBox="0 0 24 24" fill="none"
                stroke="currentColor">
                <path d="M9 18l6-6-6-6" />
              </svg></button>
            <button class="hub-btn down" data-ptz="down" title="Down"><svg viewBox="0 0 24 24" fill="none"
                stroke="currentColor">
                <path d="M6 9l6 6 6-6" />
              </svg></button>
          </div>
        </div>
      </div>

      <div class="video-overlay-msg" id="videoOverlay">
        <div class="msg-card">
          <h2 id="overlayTitle">Stream offline</h2>
          <p id="overlaySubtitle">Trying to establish connection...</p>
          <button class="action-btn" id="reloadBtn" style="margin: 0 auto;">
            <svg style="width:16px; height:16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor"
              stroke-width="2">
              <path d="M23 4v6h-6M1 20v-6h6M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15" />
            </svg>
            Reconnect
          </button>
        </div>
      </div>
    </main>

  </div>

  <noscript>
    <div class="status-toast visible">Enable JavaScript for controls</div>
  </noscript>

  <div class="status-toast" id="status" role="status" aria-live="polite">
    <div style="width: 8px; height: 8px; border-radius: 50%; background: #000;"></div>
    <span>Ready</span>
  </div>


  <script>
    const statusEl = document.getElementById('status');
    let statusTimeout;

    function showStatus(msg) {
      statusEl.textContent = msg;
      statusEl.classList.add('visible');
      clearTimeout(statusTimeout);
      statusTimeout = setTimeout(() => {
        statusEl.classList.remove('visible');
      }, 2000);
    }

    const videoEl = document.getElementById('video');
    const videoWrapperEl = document.querySelector('.video-wrapper');
    const overlayEl = document.getElementById('videoOverlay');
    const overlayTitleEl = document.getElementById('overlayTitle');
    const overlaySubtitleEl = document.getElementById('overlaySubtitle');
    const reloadBtn = document.getElementById('reloadBtn');


    const trackingToggleEl = document.getElementById('trackingToggle');
    const fsBtn = document.getElementById('fsBtn');

    let fitMode = localStorage.getItem('fitMode') || 'contain';
    function applyFitMode() {
      videoEl.style.objectFit = fitMode;
      localStorage.setItem('fitMode', fitMode);
      showStatus('Fit: ' + (fitMode === 'cover' ? 'Fill' : 'Fit'));
    }

    function setStreamStatus(ok, text) {
      // Elements removed for minimal UI
    }

    function setTrackingStatus(enabled) {
      // Elements removed for minimal UI
    }

    function showOverlay(title, subtitle) {
      overlayTitleEl.textContent = title;
      overlaySubtitleEl.textContent = subtitle;
      overlayEl.classList.add('visible');
      overlayEl.setAttribute('aria-hidden', 'false');
    }

    function hideOverlay() {
      overlayEl.classList.remove('visible');
      overlayEl.setAttribute('aria-hidden', 'true');
    }

    function reloadStream() {
      const url = new URL('/video.mjpg', window.location.href);
      url.searchParams.set('t', String(Date.now()));
      videoEl.src = url.toString();
    }

    reloadBtn.addEventListener('click', () => {
      showStatus('Reloading stream');
      reloadStream();
    });

    let ptzInFlight = 0;
    async function ptz(action) {
      try {
        ptzInFlight++;
        const res = await fetch('/ptz', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ action })
        });
        const data = await res.json();
        if (data.ok) {
          showStatus(data.message || 'Moved ' + action);
        } else {
          showStatus('Error: ' + (data.message || 'Unknown'));
        }
      } catch (e) {
        showStatus('Network Error');
      } finally {
        ptzInFlight = Math.max(0, ptzInFlight - 1);
      }
    }

    function bindHoldToRepeat(el, action) {
      let timer = null;
      let active = false;
      let lastPointerDownAt = 0;

      const start = (ev) => {
        ev.preventDefault();
        if (active) return;
        active = true;
        lastPointerDownAt = performance.now();
        ptz(action);
        timer = window.setInterval(() => {
          if (ptzInFlight > 2) return;
          ptz(action);
        }, 250);
      };
      const stop = () => {
        active = false;
        if (timer) window.clearInterval(timer);
        timer = null;
      };

      el.addEventListener('pointerdown', start);
      el.addEventListener('pointerup', stop);
      el.addEventListener('pointercancel', stop);
      el.addEventListener('pointerleave', stop);
      el.addEventListener('click', (ev) => {
        ev.preventDefault();
        if (performance.now() - lastPointerDownAt < 600) return; // avoid double fire after pointerdown
        ptz(action);
      });
    }

    document.querySelectorAll('[data-ptz]').forEach((el) => {
      const action = el.getAttribute('data-ptz');
      if (!action) return;
      if (action === 'left' || action === 'right' || action === 'up' || action === 'down' || action === 'zoom_in' || action === 'zoom_out') {
        bindHoldToRepeat(el, action);
      } else {
        el.addEventListener('click', () => ptz(action));
      }
    });

    async function toggleTracking(enable) {
      try {
        const res = await fetch('/tracking', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ enable })
        });
        const data = await res.json();
        setTrackingStatus(!!data.enabled);
        showStatus('Tracking ' + (data.enabled ? 'Enabled' : 'Disabled'));
        trackingToggleEl.checked = !!data.enabled;
      } catch (e) {
        showStatus('Error toggling tracking');
        trackingToggleEl.checked = !enable; // Revert
      }
    }

    const quickReload = document.getElementById('quickReload');
    quickReload.addEventListener('click', () => {
      showStatus('Syncing feed...');
      reloadStream();
    });

    trackingToggleEl.addEventListener('change', () => toggleTracking(trackingToggleEl.checked));


    function initTrackingState() {
      fetch('/tracking')
        .then(res => res.json())
        .then(data => {
          trackingToggleEl.checked = !!data.enabled;
          setTrackingStatus(!!data.enabled);
        })
        .catch(() => {
          setTrackingStatus(false);
        });
    }

    function initStreamState() {
      setStreamStatus(null, 'Connecting');
      showOverlay('Connecting', 'Waiting for the first frame…');
      videoEl.addEventListener('load', () => {
        setStreamStatus(true, 'Live');
        hideOverlay();
      }, { once: true });

      videoEl.addEventListener('error', () => {
        setStreamStatus(false, 'Offline');
        showOverlay('Stream offline', 'Tap Reload to reconnect.');
      });
    }

    async function pollHealth() {
      try {
        const res = await fetch('/health', { cache: 'no-store' });
        if (!res.ok) throw new Error('Bad response');
        const data = await res.json();
        const ok = data && data.frame_ok === true;
        setStreamStatus(ok, ok ? 'Live' : 'No frame');
        if (!ok) showOverlay('No frames', 'Check camera connection, then Reload.');
        if (ok) hideOverlay();
      } catch (_) {
        setStreamStatus(false, 'Offline');
        showOverlay('Offline', 'Cannot reach server. Check Wi‑Fi/VPN.');
      }
    }


    fsBtn.addEventListener('click', async () => {
      try {
        if (!document.fullscreenElement) {
          await videoWrapperEl.requestFullscreen();
          showStatus('Fullscreen');
        } else {
          await document.exitFullscreen();
        }
      } catch (_) {
        showStatus('Fullscreen not available');
      }
    });

    document.addEventListener('keydown', (ev) => {
      if (ev.repeat) return;
      const key = ev.key.toLowerCase();
      if (key === 'arrowleft') return ptz('left');
      if (key === 'arrowright') return ptz('right');
      if (key === 'arrowup') return ptz('up');
      if (key === 'arrowdown') return ptz('down');
      if (key === 't') {
        trackingToggleEl.checked = !trackingToggleEl.checked;
        return toggleTracking(trackingToggleEl.checked);
      }
      if (key === 'f') return fsBtn.click();
    });

    applyFitMode();
    initStreamState();
    initTrackingState();
    pollHealth();
    setInterval(pollHealth, 2500);
  </script>

  <script type="module">
    import {
      ObjectDetector,
      FilesetResolver
    } from "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.2";

    const video = document.getElementById("video");
    const canvasOverlay = document.getElementById("canvas_overlay");
    const ctx = canvasOverlay.getContext("2d");
    const trackingToggle = document.getElementById("trackingToggle");

    let objectDetector;
    let runningMode = "IMAGE";

    // Initialize the object detector
    const initializeObjectDetector = async () => {
      const vision = await FilesetResolver.forVisionTasks(
        "https://cdn.jsdelivr.net/npm/@mediapipe/tasks-vision@0.10.2/wasm"
      );
      objectDetector = await ObjectDetector.createFromOptions(vision, {
        baseOptions: {
          modelAssetPath: `https://storage.googleapis.com/mediapipe-models/object_detector/efficientdet_lite0/float16/1/efficientdet_lite0.tflite`,
          delegate: "GPU"
        },
        scoreThreshold: 0.4,
        runningMode: runningMode
      });
    };
    initializeObjectDetector();

    let lastVideoTime = -1;
    async function renderLoop() {
      if (!objectDetector || !trackingToggle.checked) {
        ctx.clearRect(0, 0, canvasOverlay.width, canvasOverlay.height);
        window.requestAnimationFrame(renderLoop);
        return;
      }

      // Ensure canvas size matches displayed image size for accurate coordinates
      if (video.complete && video.naturalWidth > 0) {
        // Sync canvas size with video displayed size
        const rect = video.getBoundingClientRect();
        if (canvasOverlay.width !== rect.width || canvasOverlay.height !== rect.height) {
          canvasOverlay.width = rect.width;
          canvasOverlay.height = rect.height;
        }

        // Run detection
        // Note: For MJPEG streams, we use 'detect' instead of 'detectForVideo' 
        // because we don't have a real VideoElement stream with timestamps.
        const detections = objectDetector.detect(video);
        displayDetections(detections);
      }

      window.requestAnimationFrame(renderLoop);
    }

    function displayDetections(result) {
      ctx.clearRect(0, 0, canvasOverlay.width, canvasOverlay.height);

      for (const detection of result.detections) {
        const category = detection.categories[0];
        if (category.categoryName !== 'person') continue;

        const { originX, originY, width, height } = detection.boundingBox;

        // Premium Box Design
        ctx.strokeStyle = "rgba(59, 130, 246, 0.8)";
        ctx.lineWidth = 2;
        ctx.shadowBlur = 15;
        ctx.shadowColor = "rgba(59, 130, 246, 0.5)";

        // Rounded corners for the box
        const r = 12; // radius
        ctx.beginPath();
        ctx.moveTo(originX + r, originY);
        ctx.lineTo(originX + width - r, originY);
        ctx.quadraticCurveTo(originX + width, originY, originX + width, originY + r);
        ctx.lineTo(originX + width, originY + height - r);
        ctx.quadraticCurveTo(originX + width, originY + height, originX + width - r, originY + height);
        ctx.lineTo(originX + r, originY + height);
        ctx.quadraticCurveTo(originX, originY + height, originX, originY + height - r);
        ctx.lineTo(originX, originY + r);
        ctx.quadraticCurveTo(originX, originY, originX + r, originY);
        ctx.stroke();

        // Draw label with glass effect
        ctx.shadowBlur = 0;
        ctx.fillStyle = "rgba(59, 130, 246, 0.9)";
        const label = "Baby Detected • " + Math.round(category.score * 100) + "%";
        ctx.font = "500 12px 'Outfit', sans-serif";
        const textWidth = ctx.measureText(label).width;

        // Label background
        ctx.fillRect(originX, originY - 30, textWidth + 24, 24);

        // Label text
        ctx.fillStyle = "white";
        ctx.fillText(label, originX + 12, originY - 14);
      }
    }


    window.requestAnimationFrame(renderLoop);
  </script>
</body>

